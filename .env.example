# Local preview credentials (replace on Vercel)
ADMIN_EMAIL=admin@hughes.local
ADMIN_PASSWORD=HughesAdmin2026!
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-before-vercel

# Neon / compatible Postgres connection.
# Vercel Marketplace Neon normally injects DATABASE_URL when attached.
DATABASE_URL=
# POSTGRES_URL also works for older/existing Vercel Postgres-style projects.
POSTGRES_URL=

# Vercel Blob image storage. Vercel injects this after Blob storage is connected.
BLOB_READ_WRITE_TOKEN=

# Optional production integrations
NEXT_PUBLIC_CONTACT_ENDPOINT=
NEXT_PUBLIC_MAP_EMBED_URL=
